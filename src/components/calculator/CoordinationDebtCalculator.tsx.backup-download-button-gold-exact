                {/* Hidden number — shows $?.?M until revealed */}
                <div style={{ marginBottom: 24 }}>
                  <div style={{ fontFamily: "'Playfair Display', serif", fontSize: 52, color: "#9A7A3A", lineHeight: 1, marginBottom: 6 }}>
                    $?.?M
                  </div>
                  <div style={{ fontFamily: "'DM Mono', monospace", fontSize: 10, letterSpacing: 3, color: "#7A7268", textTransform: "uppercase" }}>
                    Your Estimated Annual Coordination Debt
                  </div>
                  <div style={{ fontSize: 12, color: "#AAA09A", marginTop: 8 }}>
                    Enter your email below to reveal your exact number
                  </div>
                </div>

                <div style={{ height: 1, background: "#DDD8CE", marginBottom: 24 }} />

                <div style={{ fontFamily: "'Playfair Display', serif", fontSize: 20, color: "#1A1714", marginBottom: 6 }}>
                  Unlock your full analysis
                </div>
                <div style={{ fontSize: 13, color: "#7A7268", lineHeight: 1.6, marginBottom: 24 }}>
                  Get your complete breakdown: the four coordination taxes costing you the most, your 3-year compounding projection, and three specific recommendations for your org type.
                </div>

                <div className="input-row" style={{ display: "flex", gap: 10, marginBottom: 10 }}>
                  <input type="email" className="cdc-text-input" placeholder="your@email.com" value={email} onChange={(e) => setEmail(e.target.value)} />
                  <button className="submit-btn" disabled={!isEmailValid} onClick={handleReveal}>Reveal →</button>
                </div>
                <div className="input-row" style={{ display: "flex", gap: 12, marginBottom: 12 }}>
                  <input type="text" className="cdc-text-input" placeholder="Your name (optional)" value={userName} onChange={(e) => setUserName(e.target.value)} style={{ flex: 1 }} />
                  <input type="text" className="cdc-text-input" placeholder="Company (optional)" value={company} onChange={(e) => setCompany(e.target.value)} style={{ flex: 1 }} />
                </div>
                <div style={{ fontSize: 11, color: "#AAA09A", lineHeight: 1.5 }}>
                  No spam. Used only to send your report. Unsubscribe anytime.
                </div>
              </div>

              <div style={{ display: "flex", justifyContent: "space-between" }}>
                <button className="nav-back-btn" onClick={() => setStep(3)}>← Back</button>
                <div />
              </div>
            </div>
          </Card>

          {/* ── RESULT PANEL ── */}
          {resultRevealed && (
            <div style={{ animation: "fadeUp 0.4s ease" }}>

              {/* Hero — NOW shows the real number */}
              <div style={{ background: "#1A1714", borderRadius: 3, padding: 40, textAlign: "center", marginBottom: 20, position: "relative", overflow: "hidden" }}>
                <div style={{ position: "absolute", top: 0, left: 0, right: 0, height: 3, background: "linear-gradient(90deg,#9A7A3A,#C8A96E,#9A7A3A)" }} />
                <div style={{ fontFamily: "'DM Mono', monospace", fontSize: 10, letterSpacing: 3, color: "#7A7268", textTransform: "uppercase", marginBottom: 12 }}>
                  Estimated Coordination Debt Analysis · from7to3.com
                </div>
                <div style={{ fontFamily: "'Playfair Display', serif", fontSize: 16, color: "#7A7268", marginBottom: 24 }}>
                  {orgName}
                </div>
                <div style={{ fontFamily: "'Playfair Display', serif", fontSize: "clamp(52px,10vw,80px)", color: "#C8A96E", lineHeight: 1, marginBottom: 8 }}>
                  {fmt(debt)}
                </div>
                <div style={{ fontSize: 13, color: "#7A7268", marginBottom: 24 }}>
                  estimated annual coordination debt
                </div>
                <div style={{ fontFamily: "'DM Mono', monospace", fontSize: 12, color: "#5A5248", background: "#111", padding: "12px 20px", borderRadius: 2, display: "inline-block", marginBottom: 16 }}>
                  {headcount.toLocaleString()} × {Math.round(overheadPct * 100)}% × {fmt(avgCost)}
                </div>
                <div style={{ fontSize: 11, color: "#5A5248", fontStyle: "italic" }}>
                  This estimate is directional and intended for executive planning, not formal accounting.
                </div>
              </div>

              {/* Formula breakdown — shown in reveal */}
              <div style={{ background: "#FAFAF6", border: "1px solid #DDD8CE", borderRadius: 2, padding: 32, marginBottom: 20, boxShadow: "0 1px 3px rgba(0,0,0,0.05)" }}>
                <div style={{ fontFamily: "'DM Mono', monospace", fontSize: 10, letterSpacing: 3, color: "#9A7A3A", textTransform: "uppercase", marginBottom: 20 }}>How Your Number Was Calculated</div>

                {/* Formula cells */}
                <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 24, flexWrap: "wrap" }}>
                  {[
                    { label: "Total Headcount", value: headcount.toLocaleString(), sub: "Your org size" },
                    { op: "×" },
                    { label: "Overhead Rate", value: `${Math.round(overheadPct * 100)}%`, sub: "Coordination overhead" },
                    { op: "×" },
                    { label: "Avg. Cost", value: fmt(avgCost), sub: "Per employee / year" },
                    { op: "=" },
                    { label: "Coordination Debt", value: fmt(debt), sub: "Annual structural cost", highlight: true },
                  ].map((item, i) => {
                    if ("op" in item) {
                      return <div key={i} style={{ fontFamily: "'Playfair Display', serif", fontSize: 22, color: "#AAA09A", flexShrink: 0 }}>{item.op}</div>;
                    }
                    return (
                      <div key={i} style={{ flex: 1, minWidth: 90, background: item.highlight ? "#1A1714" : "#F5F0E8", border: `1px solid ${item.highlight ? "#3A3028" : "#DDD8CE"}`, borderRadius: 2, padding: "14px 12px", textAlign: "center" }}>
                        <div style={{ fontFamily: "'DM Mono', monospace", fontSize: 9, letterSpacing: 1, color: item.highlight ? "#9A7A3A" : "#AAA09A", textTransform: "uppercase", marginBottom: 6 }}>{item.label}</div>
                        <div style={{ fontFamily: "'Playfair Display', serif", fontSize: item.highlight ? 20 : 17, color: item.highlight ? "#C8A96E" : "#1A1714", marginBottom: 4 }}>{item.value}</div>
                        <div style={{ fontSize: 10, color: item.highlight ? "#7A7268" : "#AAA09A" }}>{item.sub}</div>
                      </div>
                    );
                  })}
                </div>

                {/* Source notes */}
                <div style={{ display: "grid", gridTemplateColumns: "repeat(3,1fr)", gap: 12 }}>
                  {[
                    { label: "30% Floor — Validated By", desc: "McKinsey (2022): management overhead consumes 40–65% of management time. LinearB (2023): 57% of feature cycle time is in coordination queues. These sources validate the floor — the Coordination Debt formula itself was developed by Sandeep Panigrahi." },
                    { label: "Overhead Rate Applied", desc: `You selected ${Math.round(overheadPct * 100)}% — reflecting your org's management layers and approval chain complexity.` },
                    { label: "Why It Compounds", desc: "Coordination Debt compounds every sprint cycle it goes unaddressed, growing through delayed decisions, rework, and approval latency." },
                  ].map(({ label, desc }) => (
                    <div key={label} style={{ background: "#F5F0E8", borderRadius: 2, padding: "14px 12px", border: "1px solid #E8E2D8" }}>
                      <div style={{ fontFamily: "'DM Mono', monospace", fontSize: 9, letterSpacing: 2, color: "#9A7A3A", textTransform: "uppercase", marginBottom: 8 }}>{label}</div>
                      <div style={{ fontSize: 12, color: "#7A7268", lineHeight: 1.6 }}>{desc}</div>
                    </div>
                  ))}
                </div>
              </div>

              {/* Download report button */}
              <div style={{ marginBottom: 20, display: "flex", justifyContent: "flex-end" }}>
                <button
                  className="share-btn"
                  style={{ padding: "12px 24px", fontSize: 11, letterSpacing: 2 }}
                  onClick={() => {
                    const html = buildReportHtml(orgName, headcount, avgCost, overheadPct, debt, industry, orgMaturity, aiStage, projectionRows, taxes, taxAmounts, recommendations);
                    const blob = new Blob([html], { type: "text/html" });
                    const url = URL.createObjectURL(blob);
                    const a = document.createElement("a");
                    a.href = url;
                    a.download = `Coordination-Debt-Report-${orgName.replace(/[^a-z0-9]/gi, "-")}.html`;
                    a.click();
                    URL.revokeObjectURL(url);
                  }}
                >
                  ↓ Download Full Report (Print to PDF)
                </button>
              </div>

              {/* Breakdown grid */}
              <div className="breakdown-grid" style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12, marginBottom: 20 }}>
                {[
                  { label: "Annual Debt", value: fmt(debt), sub: "Funding information movement, not output", accent: "#B03030" },
                  { label: "Monthly Burn", value: fmt(debt / 12), sub: "Per month in structural coordination cost", accent: "#1A1714" },
                  { label: "Compression Opportunity", value: fmt(debt * 0.67), sub: "Recoverable through three-layer restructure", accent: "#9A7A3A" },
                  { label: "Coordination Roles", value: `~${Math.round(headcount * overheadPct).toLocaleString()}`, sub: "Estimated FTEs in primary coordination functions", accent: "#1A1714" },
                ].map(({ label, value, sub, accent }) => (
                  <div key={label} style={{ background: "#FAFAF6", border: "1px solid #DDD8CE", borderRadius: 2, padding: 24, boxShadow: "0 1px 3px rgba(0,0,0,0.05)" }}>
                    <div style={{ fontFamily: "'DM Mono', monospace", fontSize: 10, letterSpacing: 2, color: "#AAA09A", textTransform: "uppercase", marginBottom: 8 }}>{label}</div>
                    <div style={{ fontFamily: "'Playfair Display', serif", fontSize: 28, color: accent, marginBottom: 4 }}>{value}</div>
                    <div style={{ fontSize: 12, color: "#7A7268", lineHeight: 1.5 }}>{sub}</div>
                  </div>
                ))}
              </div>

              {/* 3-Year projection */}
              <div style={{ background: "#FAFAF6", border: "1px solid #DDD8CE", borderRadius: 2, padding: 32, marginBottom: 20, boxShadow: "0 1px 3px rgba(0,0,0,0.05)" }}>
                <div style={{ fontFamily: "'DM Mono', monospace", fontSize: 10, letterSpacing: 3, color: "#9A7A3A", textTransform: "uppercase", marginBottom: 8 }}>3-Year Compounding Projection</div>
                <div style={{ fontFamily: "'Playfair Display', serif", fontSize: 22, color: "#1A1714", marginBottom: 20 }}>What inaction costs</div>
                <table style={{ width: "100%", borderCollapse: "collapse", fontSize: 13, marginBottom: 16 }}>
                  <thead>
                    <tr>
                      {["Year", "Coord. Cost", "Cost/Feature", "vs. Competitor"].map((h) => (
                        <th key={h} style={{ fontFamily: "'DM Mono', monospace", fontSize: 9, letterSpacing: 2, textTransform: "uppercase", color: "#AAA09A", textAlign: "left", padding: "10px 14px", borderBottom: "1px solid #E8E2D8", background: "#F5F0E8" }}>
                          {h}
                        </th>
                      ))}
                    </tr>
                  </thead>
                  <tbody>
                    {projectionRows.map((row, idx) => (
                      <tr key={idx} className={row.isCompetitor ? "proj-row-competitor" : "proj-row-yours"}>
                        <td style={{ padding: "14px 14px", borderBottom: "1px solid #EDE8DE", verticalAlign: "top" }}>
                          <span style={{ fontFamily: "'DM Mono', monospace", fontSize: 11 }}>{row.year}</span>
                          <span style={{ fontFamily: "'DM Mono', monospace", fontSize: 11, color: "#AAA09A", display: "block", marginTop: 2 }}>{row.label}</span>
                        </td>
                        <td style={{ padding: "14px 14px", borderBottom: "1px solid #EDE8DE", verticalAlign: "top" }}>
                          {fmt(row.coordCost)}
                          {idx === 1 && <span style={{ fontSize: 11, color: "#B03030", marginLeft: 6 }}>+28%</span>}
                          {idx === 2 && <span style={{ fontSize: 11, color: "#B03030", marginLeft: 6 }}>+61%</span>}
                        </td>
                        <td style={{ padding: "14px 14px", borderBottom: "1px solid #EDE8DE", verticalAlign: "top" }}>{fmt(row.costPerFeature)}</td>
                        <td style={{ padding: "14px 14px", borderBottom: "1px solid #EDE8DE", verticalAlign: "top" }}>{row.vsCompetitor}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
                <div style={{ fontSize: 12, color: "#7A7268", borderLeft: "2px solid #9A7A3A", paddingLeft: 14, lineHeight: 1.6 }}>
                  By Year 3, a competitor who compressed in Year 1 can underprice you by 40% while maintaining margins. Both organizations have AI. The divergence is structural.
                </div>
              </div>

              {/* Four taxes */}
              <div style={{ background: "#FAFAF6", border: "1px solid #DDD8CE", borderRadius: 2, padding: 32, marginBottom: 20, boxShadow: "0 1px 3px rgba(0,0,0,0.05)" }}>
                <div style={{ fontFamily: "'DM Mono', monospace", fontSize: 10, letterSpacing: 3, color: "#9A7A3A", textTransform: "uppercase", marginBottom: 8 }}>Your Coordination Taxes</div>
                <div style={{ fontFamily: "'Playfair Display', serif", fontSize: 22, color: "#1A1714", marginBottom: 20 }}>Where the debt comes from</div>
                {taxes.map((tax, i) => (
                  <div key={tax.n} style={{ display: "flex", gap: 20, alignItems: "flex-start", padding: "16px 0", borderBottom: i < taxes.length - 1 ? "1px solid #E8E2D8" : "none" }}>
                    <div style={{ fontFamily: "'DM Mono', monospace", fontSize: 10, color: "#9A7A3A", minWidth: 28, paddingTop: 3 }}>TAX {tax.n}</div>
                    <div style={{ flex: 1 }}>
                      <div style={{ display: "flex", alignItems: "baseline", gap: 8, marginBottom: 4, flexWrap: "wrap" }}>
                        <span style={{ fontFamily: "'Playfair Display', serif", fontSize: 17, color: "#1A1714" }}>{tax.name}</span>
                        <span style={{ fontFamily: "'DM Mono', monospace", fontSize: 13, color: "#B03030" }}>{fmt(taxAmounts[i])}/yr</span>
                      </div>
                      <div style={{ fontSize: 13, color: "#7A7268", lineHeight: 1.6, marginBottom: 6 }}>{tax.desc}</div>
                      <div style={{ fontFamily: "'DM Mono', monospace", fontSize: 10, color: "#AAA09A" }}>{tax.stat}</div>
                    </div>
                  </div>
                ))}
              </div>

              {/* Recommendations */}
              <div style={{ background: "#FAFAF6", border: "1px solid #DDD8CE", borderRadius: 2, padding: 32, marginBottom: 20, boxShadow: "0 1px 3px rgba(0,0,0,0.05)" }}>
                <div style={{ fontFamily: "'Playfair Display', serif", fontSize: 20, color: "#1A1714", marginBottom: 20 }}>Three Actions for Your Org</div>
                {recommendations.map((rec, i) => (
                  <div key={i} style={{ display: "flex", gap: 16, alignItems: "flex-start", padding: "16px 0", borderBottom: i < recommendations.length - 1 ? "1px solid #E8E2D8" : "none" }}>
                    <div style={{ fontFamily: "'DM Mono', monospace", fontSize: 11, color: "#9A7A3A", minWidth: 24, paddingTop: 2 }}>0{i + 1}</div>
                    <div style={{ fontSize: 14, color: "#5A5248", lineHeight: 1.6 }} dangerouslySetInnerHTML={{ __html: rec.text }} />
                  </div>
                ))}
              </div>

              {/* Share bar */}
              <div style={{ background: "#F0EBE0", border: "1px solid #DDD8CE", borderRadius: 2, padding: "24px 28px", marginBottom: 20 }}>
                <div className="share-bar-inner" style={{ display: "flex", justifyContent: "space-between", alignItems: "center", gap: 16, flexWrap: "wrap" }}>
                  <div style={{ fontSize: 13, color: "#7A7268", lineHeight: 1.5, flex: 1 }}>
                    Share your result. When a CTO and CFO see this number together, the structural conversation starts.
                  </div>
                  <div style={{ display: "flex", gap: 8 }}>
                    <button className="share-btn" onClick={handleCopy}>{copyLabel}</button>
                    <button className="share-btn" onClick={handleLinkedIn}>LinkedIn</button>
                  </div>
                </div>
              </div>

              {/* Book CTA */}
              <div style={{ background: "#1A1714", border: "1px solid #3A3028", borderRadius: 2, padding: 32, display: "flex", justifyContent: "space-between", alignItems: "center", gap: 24, flexWrap: "wrap" }}>
                <div>
                  <div style={{ fontFamily: "'DM Mono', monospace", fontSize: 9, letterSpacing: 3, color: "#9A7A3A", textTransform: "uppercase", marginBottom: 8 }}>Next Step</div>
                  <div style={{ fontFamily: "'Playfair Display', serif", fontSize: 20, color: "#F5F0E8", marginBottom: 6 }}>FROM 7 TO 3</div>
                  <div style={{ fontSize: 13, color: "#7A7268" }}>The operating manual for closing this gap — the Token Learning Control™ (TLC) framework.</div>
                </div>
                <button className="bc-btn" onClick={() => window.open("https://a.co/d/0cuWOm1F", "_blank")}>Get the Book →</button>
              </div>

              {/* Footer */}
              <div style={{ fontFamily: "'DM Mono', monospace", fontSize: 10, color: "#AAA09A", textAlign: "center", lineHeight: 1.8, marginTop: 20 }}>
                <div style={{ marginBottom: 6 }}>
                  The Coordination Debt formula (Headcount × Overhead% × Fully-Loaded Cost) was developed by Sandeep Panigrahi
                  and is introduced in <em style={{ fontStyle: "italic" }}>FROM 7 TO 3</em> (Constraint Press, 2026).
                </div>
                <div style={{ marginBottom: 6 }}>
                  The 30% overhead floor is validated by independent research: McKinsey Global Institute (2022) ·
                  LinearB Engineering Benchmarks (2023) · HBR (2017) · Ewens &amp; Giroud, NBER Working Paper 34162 (2025).
                  These sources validate the inputs; they did not originate the formula.
                </div>
                <div>© 2026 Sandeep Panigrahi · from7to3.com · Token Learning Control™ (TLC)</div>
              </div>
            </div>
          )}
        </div>
      </div>
    </>
  );
}
