  coordCost: number;
  costPerFeature: number;
  vsCompetitor: string;
  isCompetitor: boolean;
}

// ─── Helpers ──────────────────────────────────────────────────────────────────

function fmt(n: number): string {
  if (n >= 1_000_000) return "$" + (n / 1_000_000).toFixed(1) + "M";
  if (n >= 1_000) return "$" + Math.round(n / 1_000) + "K";
  return "$" + n.toLocaleString();
}

function calcDebt(headcount: number, cost: number, pct: number): number {
  return headcount * pct * cost;
}

function getProjectionRows(
  headcount: number,
  costPerHead: number,
  overheadPct: number
): ProjectionRow[] {
  const debt = calcDebt(headcount, costPerHead, overheadPct);
  const y1cpf = 60_000 * (costPerHead / 150_000);
  const currentYear = new Date().getFullYear();

  return [
    {
      year: String(currentYear),
      label: "Baseline",
      coordCost: debt,
      costPerFeature: y1cpf,
      vsCompetitor: "—",
      isCompetitor: false,
    },
    {
      year: String(currentYear + 1),
      label: "Complexity ↑",
      coordCost: debt * 1.28,
      costPerFeature: y1cpf * 1.13,
      vsCompetitor: "Gap opening",
      isCompetitor: false,
    },
    {
      year: String(currentYear + 2),
      label: "Gap widens",
      coordCost: debt * 1.61,
      costPerFeature: y1cpf * 1.25,
      vsCompetitor: "2.3× disadvantage",
      isCompetitor: false,
    },
    {
      year: "Competitor",
      label: "Compressed Y1",
      coordCost: debt * 0.33,
      costPerFeature: y1cpf * 0.55,
      vsCompetitor: "40% price advantage",
      isCompetitor: true,
    },
  ];
}

