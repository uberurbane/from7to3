function generateShareText(
  company: string,
  userName: string,
  debt: number,
  overheadPct: number
): string {
  const org = company
    ? company + "'s"
    : userName
    ? userName + "'s organization's"
    : "Our";
  return `${org} estimated annual Coordination Debt: ${fmt(debt)}/year.\n\nThis is what we're paying for coordination that AI has made structurally unnecessary — if we change the structure.\n\nFormula: Headcount × ${Math.round(overheadPct * 100)}% × Fully-Loaded Cost\n\nCalculate yours: from7to3.com\n\nBased on the TLC framework in FROM 7 TO 3 by Sandeep Panigrahi.`;
}

function generateLinkedInUrl(debt: number): string {
  const text = encodeURIComponent(
    `I just calculated our Coordination Debt: ${fmt(debt)}/year.\n\nThat's what we're paying in meetings, approvals, and status updates that AI has made structurally unnecessary — if we change the structure.\n\nCalculated using the formula from FROM 7 TO 3 by Sandeep Panigrahi: from7to3.com`
  );
  return `https://www.linkedin.com/sharing/share-offsite/?url=https://from7to3.com&summary=${text}`;
}

