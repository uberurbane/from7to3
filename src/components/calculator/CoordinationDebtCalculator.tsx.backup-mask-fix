  return (
    <div style={{ marginBottom: 40 }}>
      <div style={{ display: "flex", gap: 4, marginBottom: 8 }}>
        {[1, 2, 3, 4].map((i) => (
          <div
            key={i}
            style={{
              flex: 1,
              height: 2,
              background:
                i < step
                  ? "#C8A96E"
                  : i === step
                  ? "linear-gradient(90deg, #C8A96E, #444)"
